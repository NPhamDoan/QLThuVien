{
  "name": "library-management-system",
  "version": "1.0.0",
  "description": "Hệ thống Quản lý Thư viện - Library Management System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cd ../frontend && npm run build",
    "build:be": "tsc",
    "build:fe": "cd ../frontend && npm run build",
    "build:deploy": "node ../scripts/deploy.js",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "dev:fe": "cd ../frontend && npm run dev",
    "dev:all": "concurrently -n BE,FE -c blue,green \"npm run dev\" \"npm run dev:fe\"",
    "seed": "ts-node seed.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "fast-check": "^3.23.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
